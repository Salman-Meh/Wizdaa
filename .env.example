# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# HCM API Configuration
HCM_API_URL=http://localhost:3001
HCM_API_TIMEOUT_MS=5000
HCM_RETRY_ATTEMPTS=3
HCM_RETRY_DELAY_MS=100

# Database
DB_PATH=./data/timeoff.db
DB_RESET_ON_START=false

# Redis Cache
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL_SECONDS=3600

# Sync Configuration
BATCH_SYNC_INTERVAL_MS=3600000
BATCH_SYNC_ENABLED=true
POLLING_INTERVAL_MS=5000
STUCK_REQUEST_TIMEOUT_MS=3600000
RECOVERY_INTERVAL_MS=21600000

# Testing
MOCK_HCM_PORT=3001
MOCK_HCM_ENABLED=true
