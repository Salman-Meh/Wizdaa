{
  "name": "time-off-microservice",
  "version": "1.0.0",
  "description": "Time-off request management microservice with balance integrity",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "ts-node src/main.ts",
    "dev:mock-hcm": "ts-node tests/fixtures/mock-hcm.ts",
    "test": "jest",
    "test:unit": "jest --testPathPattern='src/.*\\.spec\\.ts$'",
    "test:integration": "jest --config jest.integration.config.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "echo 'Linting...'",
    "format": "echo 'Formatting...'"
  },
  "keywords": [
    "time-off",
    "leave-management",
    "hcm-integration",
    "balance-sync"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@nestjs/common": "^10.2.0",
    "@nestjs/core": "^10.2.0",
    "@nestjs/platform-express": "^10.2.0",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "redis": "^4.6.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.5",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.2.0"
  }
}
